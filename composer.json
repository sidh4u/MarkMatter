{
    "name": "sidh4u/mark-matter",
    "description": "A lightweight, file-based PHP content engine for building SEO-optimized websites using markdown and frontmatter.",
    "version": "1.0.0",
    "type": "project",
    "require": {
        "php": "^8.5",
        "league/commonmark": "^2.4",
        "spatie/yaml-front-matter": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
